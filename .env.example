# CRUCIBLE Environment Variables
# Copy this to .env and fill in your values

# ── PRIMARY: HuggingFace Inference API (uses your $30 HF credit) ──────────────
HF_TOKEN=hf_your_token_here

# ── HF model selection (default: Llama-3.1-8B, ~$0.0002/1K tokens) ──────────
# HF_MODEL=meta-llama/Llama-3.1-8B-Instruct            # fast, cheap
# HF_MODEL=meta-llama/Meta-Llama-3.3-70B-Instruct     # higher quality
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct                    # alternative

# ── Backend control ────────────────────────────────────────────────────────────
# LLM_BACKEND=auto          # auto-detect (HF if HF_TOKEN set, else Anthropic)
# LLM_BACKEND=hf            # force HuggingFace
# LLM_BACKEND=anthropic     # force Anthropic

# ── FALLBACK: Anthropic (used if HF_TOKEN not set or HF call fails) ───────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Training tracking (Weights & Biases) ──────────────────────────────────────
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=crucible-openenv

# ── OpenEnv Server feature flags ──────────────────────────────────────────────
USE_ARCHITECT=false
USE_ADVERSARIAL=false
USE_SHOCKS=false
SHOCK_PROBABILITY=0.25
JURISDICTION=FAR            # FAR | DFARS | EU

# ── GPU training (HF Jobs / local) ────────────────────────────────────────────
# CUDA_VISIBLE_DEVICES=0
